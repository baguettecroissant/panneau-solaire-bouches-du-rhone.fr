---
import config from '../data/config.json';
import '../styles/global.css';
import communes from '../data/communes.json';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  robots?: string;
}

const { 
  title = `${config.brandName} | Panneaux Solaires Bouches-du-Rhône (13) — Installateurs RGE`, 
  description = config.description,
  canonicalUrl,
  robots = 'index, follow'
} = Astro.props;

const siteUrl = `https://${config.domain}`;

// Auto-generate canonical URL from current page
let resolvedPathname = Astro.url.pathname;
if (!resolvedPathname.endsWith('/')) {
  resolvedPathname += '/';
}
const resolvedCanonical = canonicalUrl || `${siteUrl}${resolvedPathname}`;

// Top 10 communes for footer popular list
const topFooterCommunes = communes.slice(0, 10);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robots} />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>☀️</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />
    <link rel="alternate" hreflang="fr" href={resolvedCanonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={config.brandName} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={`${siteUrl}/images/hero-panneau-solaire-bouches-du-rhone.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/images/hero-panneau-solaire-bouches-du-rhone.png`} />

    <!-- Geo meta tags for local SEO -->
    <meta name="geo.region" content="FR-13" />
    <meta name="geo.placename" content={config.mainCity} />

    <!-- Schema.org JSON-LD slot -->
    <slot name="head" />
  </head>
  <body>
    <!-- Header -->
    <header>
      <div class="container header-inner">
        <a href="/" class="logo">
          <span>☀️</span> {config.brandName}
        </a>
        <nav class="header-nav" aria-label="Navigation principale">
          <a href="/">Accueil</a>
          <a href="/tarifs/">🧮 Tarifs 2026</a>
          <a href="/guide-autoconsommation/">Autoconsommation</a>
          <a href="/aides-panneau-solaire-13/">Aides Financières</a>
          <a href="/communes/">Villes (13)</a>
        </nav>
        <div class="header-actions">
          <a href="/devis/" class="contact-btn">
            📋 Devis <span class="hide-mobile-text">Gratuit</span>
          </a>
          <button class="mobile-menu-toggle" aria-label="Ouvrir le menu" aria-expanded="false">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content Slot -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer style="background-color: #020617; color: #f8fafc; padding: 60px 0 30px; font-size: 14.5px;">
      <div class="container" style="display: grid; grid-template-columns: 1.2fr 0.9fr 0.9fr; gap: 40px; margin-bottom: 40px;">
        <div class="footer-brand">
          <h3 style="color: #f59e0b; margin-bottom: 15px;">☀️ {config.brandName}</h3>
          <p style="color: #94a3b8; line-height: 1.6;">
            Votre guide indépendant et technique pour comparer les installateurs de panneaux solaires certifiés RGE QualiPV dans les Bouches-du-Rhône ({config.departmentCode}). Rentabilisez votre toiture provençale grâce à l'ensoleillement exceptionnel de 2 900 heures par an et réduisez immédiatement vos factures d'électricité.
          </p>
        </div>
        <div class="footer-links">
          <h4 style="color: white; margin-bottom: 15px; font-family: var(--font-heading); font-size: 16px;">Villes populaires (13)</h4>
          <ul style="list-style: none; padding: 0;">
            {topFooterCommunes.map((c) => (
              <li style="margin-bottom: 10px;">
                <a href={`/panneau-solaire-${c.slug}/`} style="color: #fef3c7; font-weight: 700; text-decoration: none;">{c.nom}</a>
                <span style="font-size: 12px; color: #64748b; margin-left: 6px;">
                  (<a href={`/installateur-solaire-${c.slug}/`} style="color: #38bdf8; text-decoration: none;" title={`Installateur RGE ${c.nom}`}>RGE QualiPV</a>)
                </span>
              </li>
            ))}
          </ul>
        </div>
        <div class="footer-links">
          <h4 style="color: white; margin-bottom: 15px; font-family: var(--font-heading); font-size: 16px;">Pages &amp; Guides</h4>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px;">
            <li><a href="/tarifs/" style="color: #cbd5e1;">Tarifs Solaire 2026</a></li>
            <li><a href="/guide-autoconsommation/" style="color: #cbd5e1;">Guide Autoconsommation</a></li>
            <li><a href="/aides-panneau-solaire-13/" style="color: #cbd5e1;">Guide Aides Financières</a></li>
            <li><a href="/devis/" style="color: #cbd5e1;">Demande de Devis Gratuit</a></li>
            <li><a href="/communes/" style="color: #cbd5e1;">Toutes les Villes du 13</a></li>
          </ul>
          <h4 style="color: white; margin-top: 25px; margin-bottom: 12px; font-family: var(--font-heading); font-size: 15px;">Dossiers Solaires</h4>
          <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px;">
            <li><a href="/guides/prix-panneaux-solaires-bouches-du-rhone-2026/" style="color: #cbd5e1;">Budget Panneaux Solaires 2026</a></li>
            <li><a href="/guides/rentabilite-panneaux-solaires-marseille-roi-economies/" style="color: #cbd5e1;">Rentabilité Solaire à Marseille</a></li>
            <li><a href="/guides/panneaux-solaires-tuiles-provencales-integration-surimposition/" style="color: #cbd5e1;">Solaire sur Tuiles Provençales</a></li>
            <li><a href="/guides/installateur-solaire-rge-qualipv-bouches-du-rhone-13/" style="color: #cbd5e1;">Choisir un Installateur QualiPV</a></li>
          </ul>
        </div>
      </div>
      <hr style="border: 0; border-top: 1px solid #1e293b; margin-bottom: 25px;" />
      <div class="container" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; color: #64748b;">
        <p>&copy; {new Date().getFullYear()} {config.brandName}. Tous droits réservés.</p>
        <p>
          <a href="/mentions-legales/" style="color: #64748b; margin-right: 15px;">Mentions Légales</a>
          <a href="/politique-confidentialite/" style="color: #64748b;">Confidentialité (RGPD)</a>
        </p>
      </div>
    </footer>

    <!-- Exit Intent Popup -->
    <ExitIntentPopup />

    <script>
      // Mobile menu toggle
      const menuToggle = document.querySelector('.mobile-menu-toggle');
      const headerNav = document.querySelector('.header-nav');
      
      if (menuToggle && headerNav) {
        menuToggle.addEventListener('click', () => {
          const isActive = menuToggle.classList.toggle('active');
          headerNav.classList.toggle('active');
          menuToggle.setAttribute('aria-expanded', String(isActive));
        });

        // Close menu when clicking outside
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (!menuToggle.contains(target) && !headerNav.contains(target)) {
            menuToggle.classList.remove('active');
            headerNav.classList.remove('active');
            menuToggle.setAttribute('aria-expanded', 'false');
          }
        });

        headerNav.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            menuToggle.classList.remove('active');
            headerNav.classList.remove('active');
            menuToggle.setAttribute('aria-expanded', 'false');
          });
        });
      }

      // Smooth scroll to devis form if present
      document.querySelectorAll('a[href="/devis/"], a[href="#devis"], .contact-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const targetForm = document.getElementById('devis');
          if (targetForm) {
            e.preventDefault();
            targetForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
            targetForm.classList.add('pulse-form');
            setTimeout(() => {
              targetForm.classList.remove('pulse-form');
            }, 3000);

            const firstBox = targetForm.querySelector('.option-box') as HTMLElement;
            if (firstBox) {
              firstBox.focus();
              firstBox.style.outline = '3px solid var(--secondary)';
              setTimeout(() => {
                if (firstBox) firstBox.style.outline = '';
              }, 3000);
            }
          }
        });
      });
    </script>
  </body>
</html>
